# Copiá este archivo como .env (para desarrollo local con `vercel dev`, no con
# `npm run dev` solo, porque las funciones de /api necesitan runtime de Vercel)
# y completá con los datos de tu proyecto de Supabase y Mercado Pago.

# --- Frontend (Vite), se puede exponer en el navegador ---
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# --- Solo servidor (funciones en /api), NUNCA con prefijo VITE_ ---
# Se configuran en Vercel > Project Settings > Environment Variables.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
MP_ACCESS_TOKEN=tu-access-token-de-mercado-pago
MP_WEBHOOK_SECRET=tu-clave-secreta-de-webhooks-de-mercado-pago
